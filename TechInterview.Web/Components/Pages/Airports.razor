@page "/airports"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav
@inject IHttpClientFactory ClientFactory

<h3>Airports</h3>

<div class="table-responsive mt-3">
    @if (_airports is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>City</th>
                    <th>Country</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in _airports)
                {
                    <tr>
                        <td>
                            <NavLink href="@($"/airports/{a.Id}")">
                                @a.Id
                            </NavLink>
                        </td>
                        <td>@a.Name</td>
                        <td>@a.City</td>
                        <td>@a.Country</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <button class="btn btn-primary" @onclick="PreviousPage" disabled="@(_offset == 0)">Previous</button>
            <button class="btn btn-primary" @onclick="NextPage">Next</button>
        </div>

        <p class="mt-2 text-muted">
            Showing @_airports.Count airports (offset @_offset, limit @_limit) total @TotalCount
        </p>
    }
</div>


@code {
    private List<AirportDto>? _airports;

    private int _offset = 0;
    private int _limit = 20;
    private int TotalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        ReadQueryParams();
        await LoadAirports();
    }

    private void ReadQueryParams()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("offset", out var offStr) && int.TryParse(offStr, out var off))
            _offset = off;

        if (query.TryGetValue("limit", out var limStr) && int.TryParse(limStr, out var lim))
            _limit = lim;
    }

    private async Task LoadAirports()
    {
        var client = ClientFactory.CreateClient("airports");

        var url = $"/api/airports?offset={_offset}&limit={_limit}";
        var response = await client.GetFromJsonAsync<AirportListResponse>(url);

        if (response is not null)
        {
            _airports = response.Items;
            TotalCount = response.TotalCount;
        }
    }

    private async Task NextPage()
    {
        _offset += _limit;
        UpdateUrl();
        await LoadAirports();
    }

    private async Task PreviousPage()
    {
        _offset = Math.Max(0, _offset - _limit);
        UpdateUrl();
        await LoadAirports();
    }

    private void UpdateUrl()
    {
        Nav.NavigateTo($"/airports?offset={_offset}&limit={_limit}", replace: true);
    }

    public class AirportDto
    {
        public string? Id { get; set; }
        public string? Name { get; set; }
        public string? City { get; set; }
        public string? Country { get; set; }
    }

    public class AirportListResponse
    {
        public List<AirportDto> Items { get; set; } = new();
        public int Offset { get; set; }
        public int Limit { get; set; }
        public int TotalCount { get; set; }
    }
}